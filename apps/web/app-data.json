        "Check(Here).Is(Home)",
        "IfTrue Unload(Home)",
        "IfTrue Craft(Home)",
        "Check(HP).Below(60)",
        "IfTrue Repair()",
        "Check(Cargo).IsFull()",
        "IfTrue MoveToward(Home)",
        "Check().Has(Scrap)",
        "IfTrue PickUp()",
        "IfFalse Move()",
        "Goto @Loop"
      ]
    },
    {
      "id": "m4",
      "labelKey": "samples.m4",
      "lines": [
        "Check().Is(Hazard)",
        "IfFalse Goto @Advance",
        "Check(HP).Below(7)",
        "IfTrue Goto @Return",
        "@Advance",
        "Move()",
        "Check().Has(Chip)",
        "IfTrue PickUp()",
        "@Return",
        "MoveToward(Home)",
        "MoveToward(Home)",
        "Check(Here).Is(Home)",
        "IfTrue Unload(Home)",
        "IfTrue Repair()"
      ]
    }
