        "@Loop",
        "Check(Energy).Below(40)",
        "IfTrue MoveToward(Home)",
        "Check(Cargo).IsFull()",
        "IfTrue MoveToward(Home)",
        "Check().Has(Scrap)",
        "IfTrue PickUp()",
        "IfFalse Move()",
        "Check(Here).Is(Home)",
        "IfTrue Unload(Home)",
        "Goto @Loop"
      ]
    },
